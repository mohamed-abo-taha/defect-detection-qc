# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/

# Data & training artifacts (large / derived — regenerate, don't commit)
data/
runs/
outputs/
*.pt
*.pth
*.onnx
*.engine
wandb/

# committed demo assets — small checkpoints + sample images, kept despite the rules above
# (so a fresh clone / cloud deploy has a working model and images to try)
!models/
!models/*.pt
!samples/
!samples/*.jpg
!samples/*.png

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
