# Training artifacts (regenerate, don't commit)
# data/: ignore everything except the ready-to-use datasets committed for convenience
data/*
!data/sample
!data/neu
!data/neu_det
runs/
outputs/
*.pt
*.pth
*.onnx
*.engine
wandb/

# committed demo assets — small checkpoints + sample images, kept despite the rules above
# (so a fresh clone / cloud deploy has a working model and images to try)
!models/
!models/*.pt
!models/*.onnx
!samples/
!samples/*.jpg
!samples/*.png

